<%# CSS tooltip - no JS needed %>
<style>
.hrzcm-tip:hover .hrzcm-tip-box {
  visibility: visible !important;
  opacity: 1 !important;
}
</style>
<%# Renders custom field inputs for CI form
    Locals: ci [HrzcmCi], ci_class_id [Integer, nil] %>
<% ci_class_id_val = ci_class_id || ci&.j_ci_class_id %>
<% ci_class = ci_class_id_val.present? ? HrzcmCiClass.find_by(id: ci_class_id_val) : nil %>
<% field_defs = ci_class&.inherited_custom_field_defs || [] %>
<% return if field_defs.empty? %>

<div class="custom-fields-ci-section"
     style="border-top:1px solid #e0e0e0; margin-top:0.8em; padding-top:0.8em;">
  <h4 style="margin-bottom:0.8em; font-size:0.95em; color:#333;">
    🔧 <%= l('hrz_cmdb.custom_fields.section_title') %>
  </h4>
  <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap:0.6em 1.2em;">
    <% field_defs.each do |fd| %>
    <% is_inherited = fd.respond_to?(:inherited) && fd.inherited %>
      <% existing = ci&.custom_field_values&.find { |v| v.j_field_def_id == fd.id } %>
      <% current_val = existing&.value || fd.default_value %>
      <div class="form-group" style="margin-bottom:0;">
        <label style="font-size:0.88em;">
          <%= fd.b_name %>
          <% if fd.is_required %><span class="required">*</span><% end %>
          <% if is_inherited %>
            <span title="<%= l('hrz_cmdb.custom_fields.inherited_from', class_name: fd.inherited_from.to_s) %>"
                  style="display:inline-block; font-size:10px; font-weight:normal;
                         background:#e8f0e8; color:#4a7a4a; border:1px solid #b0d0b0;
                         border-radius:3px; padding:0 4px; margin-left:4px; vertical-align:middle;">
              ↑ <%= fd.inherited_from %>
            </span>
          <% end %>
          <% if fd.bdescription.present? %>
            <span class="hrzcm-tip" style="position:relative; display:inline-block; margin-left:4px; vertical-align:middle;">
              <span style="display:inline-flex; align-items:center; justify-content:center;
                           width:16px; height:16px; border-radius:50%;
                           background:#3c5a99; color:#fff; font-size:11px;
                           font-weight:bold; cursor:help; line-height:1;">i</span>
              <span class="hrzcm-tip-box" style="
                visibility:hidden; opacity:0;
                position:absolute; bottom:130%; left:50%; transform:translateX(-50%);
                background:#333; color:#fff; font-size:12px; line-height:1.4;
                padding:5px 10px; border-radius:4px; min-width:160px; max-width:280px;
                white-space:normal; z-index:9999;
                box-shadow:0 2px 8px rgba(0,0,0,0.3); pointer-events:none;
                transition:opacity 0.15s ease;">
                <%= fd.bdescription %>
              </span>
            </span>
          <% end %>
        </label>
        <div class="field-wrapper">
          <% case fd.field_type %>
          <% when 'text' %>
            <%= text_field_tag "cf[#{fd.id}]", current_val,
                  class: 'form-control', maxlength: 500 %>
          <% when 'integer' %>
            <%= number_field_tag "cf[#{fd.id}]", current_val,
                  class: 'form-control form-control-short', step: 1 %>
          <% when 'float' %>
            <%= number_field_tag "cf[#{fd.id}]", current_val,
                  class: 'form-control form-control-short', step: 'any' %>
          <% when 'date' %>
            <%= date_field_tag "cf[#{fd.id}]", current_val,
                  class: 'form-control form-control-short' %>
          <% when 'bool' %>
            <%= check_box_tag "cf[#{fd.id}]", '1', current_val == '1',
                  style: 'margin-top:6px;' %>
          <% when 'list' %>
            <%= select_tag "cf[#{fd.id}]",
                  options_for_select(
                    [['— select / wybierz —', '']] + fd.list_options.map { |o| [o, o] },
                    current_val
                  ),
                  class: 'form-control' %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
