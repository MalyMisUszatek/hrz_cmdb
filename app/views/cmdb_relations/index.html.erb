<%= stylesheet_link_tag 'hrz_cmdb', plugin: 'hrz_cmdb', cache: false %>
<%= stylesheet_link_tag 'cmdb_layout_patch', plugin: 'hrz_cmdb', cache: false %>

<%= render partial: 'cmdb/cmdb_tabs' %>

<h2>Mapa relacji CMDB</h2>

<div id="cmdb-rel-layout" style="display:flex;gap:16px;align-items:flex-start">

  <!-- LEWY PANEL: filtry -->
  <div id="cmdb-rel-filters" style="min-width:260px;max-width:280px">
    <div class="box" style="padding:12px">
      <h3 style="margin:0 0 10px">Parametry</h3>

      <p>
        <label><b>CI startowe</b></label><br/>
        <select id="rel-ci-select" style="width:100%">
          <option value="">— wybierz CI —</option>
          <% @ci_list.each do |ci| %>
            <option value="<%= ci.id %>"
              <%= 'selected' if @selected_ci&.id == ci.id %>>
              <%= ci.b_name_abbr || ci.b_name_full %>
              <% if ci.ci_class %> (<%= ci.ci_class.b_name_abbr %>)<% end %>
            </option>
          <% end %>
        </select>
      </p>

      <p>
        <label><b>Kierunek</b></label><br/>
        <select id="rel-direction" style="width:100%">
          <option value="down" <%= 'selected' if @direction=='down' %>>↓ w dół (outgoing)</option>
          <option value="up"   <%= 'selected' if @direction=='up'   %>>↑ w górę (incoming)</option>
          <option value="both" <%= 'selected' if @direction=='both' %>>↕ obydwa</option>
        </select>
      </p>

      <p>
        <label><b>Typy relacji</b></label><br/>
        <% HrzcmCiRelation::RELATION_TYPES.each do |rt| %>
          <label style="display:block;font-weight:normal">
            <input type="checkbox" class="rel-type-cb" value="<%= rt %>"
              <%= 'checked' if Array(@rel_types).include?(rt) %>>
            <%= I18n.t("hrz_cmdb.ci_relations.types.#{rt}", default: rt) %>
          </label>
        <% end %>
      </p>

      <p>
        <label><b>Głębokość (max <span id="rel-depth-val"><%= @max_depth %></span>)</b></label><br/>
        <input type="range" id="rel-depth" min="1" max="15"
               value="<%= @max_depth %>" style="width:100%"
               oninput="document.getElementById('rel-depth-val').textContent=this.value">
      </p>

      <p>
        <a href="#" class="button button-positive" onclick="cmdbRelLoad();return false;">
          ▶ Pokaż mapę
        </a>
      </p>
    </div>

    <!-- Akcje na drzewie (widoczne po załadowaniu) -->
    <div id="cmdb-tree-actions" class="box" style="padding:10px;margin-top:8px;display:none">
      <b>Akcje:</b><br/>
      <a href="#" class="button" style="display:block;margin:4px 0;text-align:center"
         onclick="cmdbRestoreAll();return false;">
        ↺ Przywróć wszystkie
      </a>
      <a href="#" class="button" style="display:block;margin:4px 0;text-align:center"
         onclick="cmdbExportCsv();return false;">
        ⬇ Eksportuj widoczne (CSV)
      </a>
    </div>

    <!-- legenda -->
    <div class="box" style="padding:10px;margin-top:8px;font-size:11px">
      <b>Legenda relacji:</b><br/>
      <% HrzcmCiRelation::RELATION_TYPES.each do |rt| %>
        <span class="cmdb-rel-pill cmdb-rel-<%= rt.gsub('_','-') %>"><%= I18n.t("hrz_cmdb.ci_relations.types.#{rt}", default: rt) %></span><br/>
      <% end %>
    </div>
  </div>

  <!-- PRAWY PANEL: drzewo -->
  <div id="cmdb-rel-tree-panel" style="flex:1;min-width:0">
    <% if @selected_ci && @tree %>
      <div id="cmdb-rel-tree">
        <%= render partial: 'cmdb_relations/tree_node',
            locals: { node: @tree, depth: 0 } %>
      </div>
    <% elsif @selected_ci %>
      <div class="nodata">Brak relacji dla wybranego CI.</div>
    <% else %>
      <div class="nodata" style="padding:40px;text-align:center;color:#888">
        ← Wybierz CI i kliknij <b>Pokaż mapę</b>
      </div>
    <% end %>
  </div>

</div>

<script>
var cmdbRelTreeUrl = '<%= cmdb_relations_tree_data_path %>';
var cmdbRelI18n = {
  <% HrzcmCiRelation::RELATION_TYPES.each do |rt| %>
  "<%= rt %>": "<%= j I18n.t("hrz_cmdb.ci_relations.types.#{rt}", default: rt) %>",
  <% end %>
};

var cmdbCurrentCiName = '';
var cmdbTreeData = null;

// ── Ładowanie drzewa ───────────────────────────────────────────────────────
function cmdbRelLoad() {
  var ciSel = document.getElementById('rel-ci-select');
  var ciId  = ciSel.value;
  if (!ciId) { alert('Wybierz CI startowe'); return; }
  cmdbCurrentCiName = ciSel.options[ciSel.selectedIndex].text.trim().split(' (')[0];

  var dir   = document.getElementById('rel-direction').value;
  var depth = document.getElementById('rel-depth').value;
  var types = Array.from(document.querySelectorAll('.rel-type-cb:checked')).map(function(cb){return cb.value;});
  if (!types.length) { alert('Zaznacz co najmniej jeden typ relacji'); return; }

  document.getElementById('cmdb-rel-tree-panel').innerHTML =
    '<div style="padding:20px;color:#888">Ładowanie...</div>';
  document.getElementById('cmdb-tree-actions').style.display = 'none';

  var params = new URLSearchParams();
  params.append('ci_id', ciId);
  params.append('direction', dir);
  params.append('max_depth', depth);
  types.forEach(function(t){ params.append('rel_types[]', t); });

  fetch(cmdbRelTreeUrl + '?' + params.toString(), {
    headers: {'X-Requested-With': 'XMLHttpRequest',
              'X-CSRF-Token': document.querySelector('meta[name=csrf-token]')?.content || ''}
  })
  .then(function(r){ return r.json(); })
  .then(function(data) {
    cmdbTreeData = data;
    document.getElementById('cmdb-rel-tree-panel').innerHTML =
      '<div id="cmdb-rel-tree">' + cmdbRenderNode(data, 0) + '</div>';
    document.getElementById('cmdb-tree-actions').style.display = 'block';
  })
  .catch(function(e){
    document.getElementById('cmdb-rel-tree-panel').innerHTML =
      '<div class="error">Błąd ładowania: ' + e.message + '</div>';
  });
}

// ── Renderowanie węzła ─────────────────────────────────────────────────────
function cmdbRenderNode(node, depth) {
  var indent   = depth * 28;
  var relBadge = node.via
    ? '<span class="cmdb-rel-pill cmdb-rel-' + node.via.replace(/_/g,'-') + '">'
      + (node.direction_in ? '↑ ' : '↓ ') + (cmdbRelI18n[node.via] || node.via) + '</span> '
    : '';
  var cls = node.ci_class
    ? ' <em style="color:#888;font-size:11px">(' + cmdbEsc(node.ci_class) + ')</em>' : '';
  var st = node.status
    ? ' <span class="cmdb-status-badge">' + cmdbEsc(node.status) + '</span>' : '';
  var toggle = (node.children && node.children.length)
    ? '<a href="#" class="cmdb-toggle" onclick="cmdbToggle(this);return false;">▼</a> '
    : '<span style="display:inline-block;width:16px"></span> ';

  // Przycisk ukrywania (nie dla korzenia depth==0)
  var hideBtn = depth > 0
    ? ' <a href="#" class="cmdb-hide-node" title="Ukryj tę gałąź"'
      + ' onclick="cmdbHideNode(this);return false;">✕</a>'
    : '';

  var html = '<div class="cmdb-tree-node" data-depth="' + depth + '"'
    + ' data-name="' + cmdbEsc(node.name) + '"'
    + ' data-class="' + cmdbEsc(node.ci_class || '') + '"'
    + ' data-status="' + cmdbEsc(node.status || '') + '"'
    + ' data-via="' + cmdbEsc(node.via || '') + '"'
    + ' data-dir="' + (node.direction_in ? 'in' : node.via ? 'out' : '') + '"'
    + ' style="margin-left:' + indent + 'px">'
    + toggle + relBadge
    + '<span class="cmdb-node-name">' + cmdbEsc(node.name) + '</span>'
    + cls + st + hideBtn
    + '</div>';

  if (node.children && node.children.length) {
    html += '<div class="cmdb-tree-children">';
    node.children.forEach(function(c){ html += cmdbRenderNode(c, depth + 1); });
    html += '</div>';
  }
  return html;
}

// ── Helpers ────────────────────────────────────────────────────────────────
function cmdbEsc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function cmdbToggle(a) {
  var node     = a.closest('.cmdb-tree-node');
  var children = node.nextElementSibling;
  if (children && children.classList.contains('cmdb-tree-children')) {
    var hidden = children.style.display === 'none';
    children.style.display = hidden ? '' : 'none';
    a.textContent = hidden ? '▼' : '►';
  }
}

// ── Ukrywanie gałęzi ───────────────────────────────────────────────────────
function cmdbHideNode(btn) {
  var nodeDiv  = btn.closest('.cmdb-tree-node');
  var children = nodeDiv.nextElementSibling;
  // Ukryj węzeł
  nodeDiv.style.display = 'none';
  // Ukryj dzieci (cała gałąź)
  if (children && children.classList.contains('cmdb-tree-children')) {
    children.style.display = 'none';
  }
}

// ── Przywróć wszystkie ─────────────────────────────────────────────────────
function cmdbRestoreAll() {
  var tree = document.getElementById('cmdb-rel-tree');
  if (!tree) return;
  tree.querySelectorAll('.cmdb-tree-node, .cmdb-tree-children').forEach(function(el) {
    el.style.display = '';
  });
  // Przywróć strzałki toggle
  tree.querySelectorAll('.cmdb-toggle').forEach(function(a) {
    a.textContent = '▼';
  });
}

// ── Eksport CSV (tylko widoczne węzły) ─────────────────────────────────────
function cmdbExportCsv() {
  var tree = document.getElementById('cmdb-rel-tree');
  if (!tree) { alert('Brak danych do eksportu'); return; }

  var rows = [['CI nazwa', 'Klasa CI', 'Status', 'Typ relacji', 'Kierunek', 'Głębokość']];

  tree.querySelectorAll('.cmdb-tree-node').forEach(function(el) {
    // Pomiń ukryte węzły
    if (el.style.display === 'none') return;
    // Sprawdź czy rodzic nie jest ukryty
    var p = el.parentElement;
    while (p && p.id !== 'cmdb-rel-tree') {
      if (p.style.display === 'none') return;
      p = p.parentElement;
    }
    rows.push([
      el.dataset.name    || '',
      el.dataset.class   || '',
      el.dataset.status  || '',
      el.dataset.via     || '(korzeń)',
      el.dataset.dir === 'in' ? 'incoming' : el.dataset.via ? 'outgoing' : '',
      el.dataset.depth   || '0'
    ]);
  });

  if (rows.length <= 1) { alert('Brak widocznych węzłów do eksportu'); return; }

  var csv = rows.map(function(r) {
    return r.map(function(c) {
      var s = String(c).replace(/"/g, '""');
      return /[",\n]/.test(s) ? '"' + s + '"' : s;
    }).join(',');
  }).join('\r\n');

  var bom  = '\uFEFF'; // BOM dla polskich znaków w Excel
  var blob = new Blob([bom + csv], { type: 'text/csv;charset=utf-8;' });
  var url  = URL.createObjectURL(blob);
  var a    = document.createElement('a');
  var date = new Date().toISOString().slice(0,10);
  a.href     = url;
  a.download = 'cmdb_relacje_' + cmdbCurrentCiName.replace(/[^a-zA-Z0-9_-]/g,'_') + '_' + date + '.csv';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}
</script>

