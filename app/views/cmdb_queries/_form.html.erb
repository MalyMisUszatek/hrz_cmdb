<%
  entity_type          = @query.entity_type || 'ci'
  avail_cols           = HrzcmQuery::AVAILABLE_COLUMNS[entity_type] || []
  selected_cols        = @query.columns_data
  avail_cols_remaining = avail_cols.map { |c| c[0] }.reject { |c| selected_cols.include?(c) }
  text_fields    = HrzcmQuery::TEXT_FIELDS
  fk_fields      = HrzcmQuery::FK_FIELDS
  virtual_fields = HrzcmQuery::VIRTUAL_FIELDS
  rel_filter     = HrzcmQuery::RELATION_FILTER
  text_ops = [['zawiera (~)','~'],['nie zawiera (!~)','!~'],['r√≥wna siƒô (=)','='],['nie r√≥wna siƒô (!=)','!=']]
  fk_ops   = [['r√≥wna siƒô (=)','='],['nie r√≥wna siƒô (!=)','!=']]
  date_ops = [['=','='],['>=','>='],['<=','<='],['miƒôdzy','between']]
  rel_ops  = [['ma relacjƒô typu (=)','=']]
  filters_data = @query.filters_data
%>
<%= form_with model: @query,
      url: @query.new_record? ? cmdb_queries_path : cmdb_query_path(@query),
      method: @query.new_record? ? :post : :patch,
      local: true, id: 'cmdb-query-form' do |f| %>
  <% if @query.errors.any? %>
    <div id="errorExplanation">
      <ul><% @query.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>
  <%= f.hidden_field :filters, id: 'hidden_filters' %>
  <%= f.hidden_field :columns, id: 'hidden_columns' %>
  <div class="box tabular">
    <p><%= f.label :name, l(:field_name) %><span class="required"> *</span>
       <%= f.text_field :name, size: 60 %></p>
    <p><%= f.label :description, l(:field_description) %>
       <%= f.text_area :description, rows: 3, cols: 60 %></p>
    <p><%= f.label :entity_type, l('hrz_cmdb.queries.entity_type') %>
      <% if @query.new_record? %>
        <%= f.select :entity_type,
            HrzcmQuery::ENTITY_TYPES.map { |k| [l("hrz_cmdb.queries.entity_#{k}"), k] },
            {}, { id: 'entity_type_select' } %>
      <% else %>
        <%= f.hidden_field :entity_type %>
        <strong><%= l("hrz_cmdb.queries.entity_#{@query.entity_type}") %></strong>
      <% end %>
    </p>
    <p><%= f.label :is_public, l('hrz_cmdb.queries.is_public') %>
       <%= f.check_box :is_public %></p>
  </div>

  <fieldset id="filters-fieldset">
    <legend><%= l('hrz_cmdb.queries.filters') %></legend>
    <table class="query-filters">
      <tbody id="filters-tbody">
        <% filters_data.each do |f_row| %>
          <tr class="filter-row">
            <td>
              <select class="filter-field" onchange="cmdbOnFieldChange(this)">
                <% avail_cols.reject { |c| virtual_fields.include?(c[0]) }.each do |col| %>
                  <option value="<%= col[0] %>" <%= 'selected' if f_row['field'] == col[0] %>>
                    <%= l("hrz_cmdb.fields.#{col[0]}", default: col[0]) %>
                  </option>
                <% end %>
                <% if entity_type == 'ci' %>
                  <option value="<%= rel_filter %>" <%= 'selected' if f_row['field'] == rel_filter %>>
                    <%= l('hrz_cmdb.queries.has_relation_type', default: 'Ma relacjƒô typu') %>
                  </option>
                <% end %>
              </select>
            </td>
            <td>
              <select class="filter-op">
                <% (f_row['field'] == rel_filter ? rel_ops : text_ops).each do |label, val| %>
                  <option value="<%= val %>" <%= 'selected' if f_row['operator'] == val %>><%= label %></option>
                <% end %>
              </select>
            </td>
            <td class="filter-val-td">
              <% if f_row['field'] == rel_filter %>
                <select class="filter-val" style="min-width:180px">
                  <option value="any"  <%= 'selected' if f_row['value']=='any'  %>>‚Äî dowolna relacja ‚Äî</option>
                  <option value="none" <%= 'selected' if f_row['value']=='none' %>>‚Äî brak relacji ‚Äî</option>
                  <% HrzcmQuery::RELATION_TYPES.each do |rt| %>
                    <option value="<%= rt %>" <%= 'selected' if f_row['value']==rt %>><%= rt %></option>
                  <% end %>
                </select>
              <% else %>
                <input type="text" class="filter-val" value="<%= f_row['value'] %>" size="30" />
              <% end %>
            </td>
            <td><a href="#" onclick="this.closest('tr').remove();return false;" class="icon icon-del"></a></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <p style="margin-top:6px">
      <strong>Dodaj filtr:</strong>
      <select id="add-filter-field">
        <option value="">‚Äî wybierz pole ‚Äî</option>
        <% avail_cols.reject { |c| virtual_fields.include?(c[0]) }.each do |col| %>
          <option value="<%= col[0] %>"
            data-type="<%= text_fields.include?(col[0]) ? 'text' : fk_fields.include?(col[0]) ? 'fk' : 'date' %>">
            <%= l("hrz_cmdb.fields.#{col[0]}", default: col[0]) %>
          </option>
        <% end %>
        <% if entity_type == 'ci' %>
          <option value="<%= rel_filter %>" data-type="relation">
            <%= l('hrz_cmdb.queries.has_relation_type', default: 'Ma relacjƒô typu') %>
          </option>
        <% end %>
      </select>
      <a href="#" class="button" onclick="cmdbAddFilter();return false;">+ Dodaj</a>
    </p>
  </fieldset>

  <fieldset id="columns-fieldset">
    <legend><%= l('hrz_cmdb.queries.columns') %></legend>
    <table><tr>
      <td style="vertical-align:top">
        <label><strong>Dostƒôpne kolumny</strong></label><br/>
        <select id="available-columns" size="12" style="width:220px;min-height:180px;border:1px solid #ccc;padding:4px" multiple>
          <% avail_cols_remaining.each do |col| %>
            <option value="<%= col %>"><%= l("hrz_cmdb.fields.#{col}", default: col) %></option>
          <% end %>
        </select>
      </td>
      <td style="vertical-align:middle;padding:0 8px;text-align:center">
        <a href="#" class="button" style="display:block;margin:4px 0" onclick="cmdbMoveCols('right');return false;">‚Üí</a>
        <a href="#" class="button" style="display:block;margin:4px 0" onclick="cmdbMoveCols('left');return false;">‚Üê</a>
      </td>
      <td style="vertical-align:top">
        <label><strong>Wybrane kolumny</strong></label><br/>
        <select id="selected-columns" size="12" style="width:220px;min-height:180px;border:1px solid #ccc;padding:4px" multiple>
          <% selected_cols.each do |col| %>
            <option value="<%= col %>"><%= l("hrz_cmdb.fields.#{col}", default: col) %></option>
          <% end %>
        </select>
      </td>
      <td style="vertical-align:middle;padding:0 4px;text-align:center">
        <a href="#" class="button" style="display:block;margin:4px 0" onclick="cmdbMoveOrder('top');return false;">‚Üë‚Üë</a>
        <a href="#" class="button" style="display:block;margin:4px 0" onclick="cmdbMoveOrder('up');return false;">‚Üë</a>
        <a href="#" class="button" style="display:block;margin:4px 0" onclick="cmdbMoveOrder('down');return false;">‚Üì</a>
        <a href="#" class="button" style="display:block;margin:4px 0" onclick="cmdbMoveOrder('bottom');return false;">‚Üì‚Üì</a>
      </td>
    </tr></table>
  </fieldset>

  <fieldset>
    <legend>Opcje</legend>
    <div class="box tabular">
      <p><%= f.label :sort_column, l('hrz_cmdb.queries.sort_column') %>
         <%= f.select :sort_column,
             [['','']] + avail_cols.reject { |c| HrzcmQuery::VIRTUAL_FIELDS.include?(c[0]) }
                                   .map { |c| [l("hrz_cmdb.fields.#{c[0]}", default: c[0]), c[0]] } %></p>
      <p><%= f.label :sort_direction, l('hrz_cmdb.queries.sort_direction') %>
         <%= f.select :sort_direction,
             [[l('hrz_cmdb.queries.sort_asc'),'asc'],[l('hrz_cmdb.queries.sort_desc'),'desc']] %></p>
    </div>
  </fieldset>
  <p>
    <%= f.submit l(:button_save), class: 'button-positive', id: 'query-submit-btn' %>
    <%= link_to l(:button_cancel),
        @query.new_record? ? cmdb_queries_path : results_cmdb_query_path(@query),
        class: 'button' %>
  </p>
<% end %>
<script>
var cmdbTextOps  = [['zawiera (~)','~'],['nie zawiera (!~)','!~'],['r√≥wna siƒô (=)','='],['nie r√≥wna siƒô (!=)','!=']];
var cmdbFkOps    = [['r√≥wna siƒô (=)','='],['nie r√≥wna siƒô (!=)','!=']];
var cmdbDateOps  = [['=','='],['>=','>='],['<=','<='],['miƒôdzy','between']];
var cmdbRelOps   = [['ma relacjƒô typu (=)','=']];
var cmdbRelTypes = [{v:'any',l:'‚Äî dowolna relacja ‚Äî'},{v:'none',l:'‚Äî brak relacji ‚Äî'},
  {v:'connected_to',l:'connected_to'},{v:'contains',l:'contains'},
  {v:'installed_on',l:'installed_on'},{v:'runs_on',l:'runs_on'},{v:'virtualizes',l:'virtualizes'}];
var cmdbFkUrl = '<%= cmdb_fk_options_path %>';
var cmdbFkCache = {};

function cmdbGetOps(t){
  if(t==='date')     return cmdbDateOps;
  if(t==='fk')       return cmdbFkOps;
  if(t==='relation') return cmdbRelOps;
  return cmdbTextOps;
}
function cmdbBuildValueInput(fv,ft,ev){
  if(ft==='relation'){
    var s=document.createElement('select');s.className='filter-val';s.style.minWidth='180px';
    cmdbRelTypes.forEach(function(r){var o=document.createElement('option');o.value=r.v;o.text=r.l;if(r.v===ev)o.selected=true;s.appendChild(o);});
    return s;
  }
  if(ft==='fk'){
    var s=document.createElement('select');s.className='filter-val';s.style.minWidth='180px';
    var load=function(d){s.innerHTML='<option value="">‚Äî wybierz ‚Äî</option>';d.forEach(function(o){var x=document.createElement('option');x.value=o.value;x.text=o.label;if(String(o.value)===String(ev))x.selected=true;s.appendChild(x);});};
    if(cmdbFkCache[fv]){load(cmdbFkCache[fv]);}else{$.getJSON(cmdbFkUrl,{field:fv},function(d){cmdbFkCache[fv]=d;load(d);});}
    return s;
  }
  var i=document.createElement('input');i.type='text';i.className='filter-val';i.size=30;i.value=ev||'';return i;
}
function cmdbFieldType(fv){
  var s=document.getElementById('add-filter-field');
  for(var i=1;i<s.options.length;i++){if(s.options[i].value===fv)return s.options[i].dataset.type||'text';}
  return 'text';
}
function cmdbAddFilter(){
  var sel=document.getElementById('add-filter-field');
  var fv=sel.value;if(!fv)return;
  var ft=cmdbFieldType(fv);
  var ops=cmdbGetOps(ft);
  var opH=ops.map(function(o){return '<option value="'+o[1]+'">'+o[0]+'</option>';}).join('');
  var fH='';for(var i=1;i<sel.options.length;i++){fH+='<option value="'+sel.options[i].value+'"'+(sel.options[i].value===fv?' selected':'')+'>'+sel.options[i].text+'</option>';}
  var tr=document.createElement('tr');tr.className='filter-row';
  tr.innerHTML='<td><select class="filter-field" onchange="cmdbOnFieldChange(this)">'+fH+'</select></td>'
    +'<td><select class="filter-op">'+opH+'</select></td>'
    +'<td class="filter-val-td"></td>'
    +'<td><a href="#" onclick="this.closest(\'tr\').remove();return false;" class="icon icon-del"></a></td>';
  document.getElementById('filters-tbody').appendChild(tr);
  tr.querySelector('.filter-val-td').appendChild(cmdbBuildValueInput(fv,ft,''));
  sel.value='';
}
function cmdbOnFieldChange(fs){
  var row=fs.closest('tr');var fv=fs.value;var ft=cmdbFieldType(fv);
  var ops=cmdbGetOps(ft);
  row.querySelector('.filter-op').innerHTML=ops.map(function(o){return '<option value="'+o[1]+'">'+o[0]+'</option>';}).join('');
  var vtd=row.querySelector('.filter-val-td');vtd.innerHTML='';
  vtd.appendChild(cmdbBuildValueInput(fv,ft,''));
}
document.addEventListener('DOMContentLoaded',function(){
  var as=document.getElementById('add-filter-field');
  document.querySelectorAll('#filters-tbody .filter-row').forEach(function(row){
    var fs=row.querySelector('.filter-field');var fv=fs?fs.value:'';
    var ft=cmdbFieldType(fv);
    if(ft==='fk'){
      var old=row.querySelector('.filter-val');var ev=old?old.value:'';
      var vtd=old?old.parentNode:null;
      if(vtd){vtd.className='filter-val-td';vtd.innerHTML='';vtd.appendChild(cmdbBuildValueInput(fv,'fk',ev));}
    }
    if(fs)fs.setAttribute('onchange','cmdbOnFieldChange(this)');
  });
});
function cmdbMoveCols(d){
  var s=document.getElementById(d==='right'?'available-columns':'selected-columns');
  var t=document.getElementById(d==='right'?'selected-columns':'available-columns');
  Array.from(s.selectedOptions).forEach(function(o){t.appendChild(o);});
}
function cmdbMoveOrder(d){
  var sel=document.getElementById('selected-columns');var s=Array.from(sel.selectedOptions);if(!s.length)return;
  if(d==='top')s.forEach(function(o){sel.insertBefore(o,sel.firstChild);});
  else if(d==='bottom')s.reverse().forEach(function(o){sel.appendChild(o);});
  else if(d==='up')s.forEach(function(o){var p=o.previousElementSibling;if(p)sel.insertBefore(o,p);});
  else if(d==='down')s.reverse().forEach(function(o){var n=o.nextElementSibling;if(n)sel.insertBefore(n,o);});
}
document.getElementById('cmdb-query-form').addEventListener('submit',function(){
  var f=[];
  document.querySelectorAll('#filters-tbody .filter-row').forEach(function(row){
    var field=row.querySelector('.filter-field').value;
    var op=row.querySelector('.filter-op').value;
    var ve=row.querySelector('.filter-val');var val=ve?ve.value:'';
    if(field&&val!=='')f.push({field:field,operator:op,value:val});
  });
  document.getElementById('hidden_filters').value=JSON.stringify(f);
  var cols=Array.from(document.getElementById('selected-columns').options).map(function(o){return o.value;});
  document.getElementById('hidden_columns').value=JSON.stringify(cols);
});
</script>
